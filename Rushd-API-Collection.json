{
  "info": {
    "name": "Rushd Islamic App API",
    "description": "API Collection for Rushd Islamic Companion App (Flutter)\n\n## Authentication\n\n### For Flutter/Mobile Apps:\nAdd header `x-api-key` with your API key.\n\n### For Web Apps:\nAdd headers:\n- `x-app-ts`: Current Unix timestamp\n- `x-app-token`: HMAC-SHA256(ts, API_SECRET)\n\n## Base URL\n`http://localhost:3000/api/v1`\n\n## Environment Variables\n- `{{baseUrl}}`: http://localhost:3000/api/v1\n- `{{apiKey}}`: Your mobile API key\n- `{{timestamp}}`: {{$timestamp}}\n- `{{webToken}}`: HMAC token (generate in pre-request script)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api/v1",
      "type": "string"
    },
    {
      "key": "apiKey",
      "value": "your-api-key-here",
      "type": "string"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Generate Web HMAC Token",
          "const timestamp = Math.floor(Date.now() / 1000);",
          "const secret = 'rushd-app-secret-change-this-in-production';",
          "const crypto = require('crypto');",
          "const token = crypto.createHmac('sha256', secret).update(timestamp.toString()).digest('hex');",
          "pm.collectionVariables.set('timestamp', timestamp);",
          "pm.collectionVariables.set('webToken', token);"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Quran",
      "item": [
        {
          "name": "Get Quran Meta",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/quran/meta",
            "header": [
              { "key": "x-api-key", "value": "{{apiKey}}", "disabled": false },
              { "key": "x-app-ts", "value": "{{timestamp}}", "disabled": false },
              { "key": "x-app-token", "value": "{{webToken}}", "disabled": false }
            ]
          }
        },
        {
          "name": "Get Surah List",
          "request": {
            "method": "GET",
